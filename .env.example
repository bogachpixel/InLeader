# Скопируйте этот файл в .env и заполните своими значениями
# НЕ добавляйте .env в git — он содержит секреты!

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
ADMIN_ID=your_telegram_admin_user_id_here

# FreeKassa (пополнение InCoins)
FREEKASSA_MERCHANT_ID=your_merchant_id
FREEKASSA_SECRET1=your_secret1_from_freekassa
FREEKASSA_SECRET2=your_secret2_from_freekassa
FREEKASSA_PORT=8081
NGROK_URL=https://your-ngrok-subdomain.ngrok-free.app

# CryptoPay (@CryptoBot) — вебхук на .../cryptopay/webhook
CRYPTOPAY_TOKEN=ваш_токен_приложения_из_CryptoBot
CRYPTOPAY_COINS_PER_USD=100
